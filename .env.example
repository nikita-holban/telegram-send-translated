# Telegram bot token from @BotFather
BOT_TOKEN=

# --- Translation providers ---------------------------------------------------
# Configure at least one. Each user picks their provider with /provider;
# DEFAULT_PROVIDER is used for everyone who hasn't chosen.

# Anthropic (Claude) — https://console.anthropic.com/
# Required only if the Anthropic provider is used.
ANTHROPIC_API_KEY=

# Optional: Claude model used for translation (default: claude-haiku-4-5,
# chosen for low inline-query latency)
ANTHROPIC_MODEL=claude-haiku-4-5

# Google Cloud Translation LLM — set GOOGLE_PROJECT_ID to enable it.
# Requires the Cloud Translation API enabled on the project and a
# service-account key file pointed to by GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_PROJECT_ID=
GOOGLE_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
# Optional: hard spending cap in USD for Google Translation LLM ($300/M chars).
# Requests that would exceed this are rejected with a user-visible error.
# Leave blank for no limit.
GOOGLE_BUDGET_USD=5.0

# Optional: default provider for users who haven't run /provider
# (one of: anthropic, google)
DEFAULT_PROVIDER=anthropic

# -----------------------------------------------------------------------------

# Optional: fallback target language for users who haven't run /setlang
DEFAULT_TARGET_LANG=English

# Optional: path to the SQLite database file
DB_PATH=data/bot.db

# --- Webhook (production) -----------------------------------------------------
# Leave all blank for local dev — bot falls back to polling mode automatically.
WEBHOOK_URL=
WEBHOOK_PORT=8445
WEBHOOK_PATH=/translate/webhook
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=
